{
  "openapi": "3.1.0",
  "info": {
    "title": "User Files",
    "description": "Browse and read user files. All queries require a key. Request it from the user if needed.",
    "version": "v1.0.2"
  },
  "servers": [
    {
      "url": "https://jarvis.kehlet.dev/hub"
    }
  ],
  "paths": {
    "/listprojects": {
      "post": {
        "description": "Gets a list of projects",
        "operationId": "ListProjects",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ListProjectsSchema"
              }
            }
          },
          "required": true
        },
        "deprecated": false
      }
    },
    "/getprojectdetails": {
      "post": {
        "description": "Get the details of the given project. Includes readme, todo, and notes.",
        "operationId": "GetProjectDetails",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetProjectDetailsSchema"
              }
            }
          },
          "required": true
        },
        "deprecated": false
      }
    },
    "/listprojectdirectory": {
      "post": {
        "description": "Get the items in the given directory",
        "operationId": "ListProjectDirectory",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ListProjectDirectorySchema"
              }
            }
          }
        }
      }
    },
    "/openfile": {
      "post": {
        "description": "Get file content",
        "operationId": "OpenFile",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OpenFileSchema"
              }
            }
          },
          "required": true
        }
      }
    },
    "/writefile": {
      "post": {
        "description": "Write file content",
        "operationId": "WriteFile",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WriteFileSchema"
              }
            }
          },
          "required": true
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ListProjectsSchema": {
        "properties": {
          "key": {
            "type": "string",
            "title": "key",
            "description": "Key provided by the user."
          }
        },
        "type": "object",
        "required": [
          "key"
        ],
        "title": "ListProjectsSchema"
      },
      "GetProjectDetailsSchema": {
        "properties": {
          "key": {
            "type": "string",
            "title": "key",
            "description": "Key provided by the user."
          },
          "command": {
            "type": "object",
            "title": "Command details",
            "required": [
              "project_name"
            ],
            "properties": {
              "project_name": {
                "type": "string",
                "title": "project_name",
                "description": "Name of the project."
              }
            }
          }
        },
        "type": "object",
        "required": [
          "key",
          "command"
        ],
        "title": "GetProjectDetailsSchema"
      },
      "ListProjectDirectorySchema": {
        "properties": {
          "key": {
            "type": "string",
            "title": "key",
            "description": "Key provided by the user."
          },
          "command": {
            "type": "object",
            "title": "Command details",
            "properties": {
              "project_name": {
                "type": "string",
                "title": "project_name",
                "description": "Name of the project."
              },
              "path": {
                "type": "string",
                "title": "path",
                "description": "The path to list the items of."
              }
            },
            "required": [
              "project_name",
              "path"
            ]
          }
        },
        "type": "object",
        "required": [
          "key",
          "command"
        ],
        "title": "ListProjectDirectorySchema"
      },
      "OpenFileSchema": {
        "properties": {
          "key": {
            "type": "string",
            "title": "key",
            "description": "Key provided by the user."
          },
          "command": {
            "type": "object",
            "title": "Command details",
            "properties": {
              "project_name": {
                "type": "string",
                "title": "project_name",
                "description": "Name of the project."
              },
              "path": {
                "type": "string",
                "title": "path",
                "description": "The path to the file."
              }
            },
            "required": [
              "project_name",
              "path"
            ]
          }
        },
        "type": "object",
        "required": [
          "key",
          "command"
        ],
        "title": "OpenFileSchema"
      },
      "WriteFileSchema": {
        "properties": {
          "key": {
            "type": "string",
            "title": "key",
            "description": "Key provided by the user."
          },
          "command": {
            "type": "object",
            "title": "Command details",
            "properties": {
              "project_name": {
                "type": "string",
                "title": "project_name",
                "description": "Name of the project."
              },
              "file_path": {
                "type": "string",
                "title": "file_path",
                "description": "The path to the file."
              },
              "content": {
                "type": "string",
                "title": "content",
                "description": "The content that will be written"
              },
              "mode": {
                "type": "string",
                "title": "mode",
                "description": "The write mode. append/write"
              }
            },
            "required": [
              "project_name",
              "file_path",
              "content",
              "mode"
            ]
          }
        },
        "type": "object",
        "required": [
          "key",
          "command"
        ],
        "title": "OpenFileSchema"
      }
    }
  }
}
